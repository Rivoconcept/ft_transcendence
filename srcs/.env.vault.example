# =========================
# PostgreSQL
# =========================
POSTGRES_PASSWORD=rootpassword

# =========================
# PgAdmin
# =========================
PGADMIN_DEFAULT_PASSWORD=admin

# =========================
# Backend
# =========================
NODE_ENV=development
BACKEND_PORT=3000
DB_HOST=postgres
DB_PORT=5432

# =========================
# User authentification
# =========================
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d
JWT_SECRET=your_jwt_secret
REFRESH_SECRET=your_refresh_secret

