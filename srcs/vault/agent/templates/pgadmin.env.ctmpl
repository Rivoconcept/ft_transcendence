{{- with secret "secret/data/GameHub/pgadmin" -}}
PGADMIN_SERVER_NAME={{ .Data.data.PGADMIN_SERVER_NAME }}
PGADMIN_DEFAULT_EMAIL={{ .Data.data.PGADMIN_DEFAULT_EMAIL }}
PGADMIN_DEFAULT_PASSWORD={{ .Data.data.PGADMIN_DEFAULT_PASSWORD }}
SMTP_HOST={{ .Data.data.SMTP_HOST }}
SMTP_PORT={{ .Data.data.SMTP_PORT }}
SMTP_USER={{ .Data.data.SMTP_USER }}
SMTP_PASS={{ .Data.data.SMTP_PASS }}
SMTP_FROM={{ .Data.data.SMTP_FROM }}
{{- end -}}
{{- with secret "secret/data/GameHub/postgres"}}
DB_HOST={{ .Data.data.DB_HOST }}
DB_PORT={{ .Data.data.DB_PORT }}
POSTGRES_USER={{ .Data.data.POSTGRES_USER }}
POSTGRES_PASSWORD={{ .Data.data.POSTGRES_PASSWORD }}
{{- end -}}